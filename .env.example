# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/larptubex"

# JWT signing key — минимум 32 символа, openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-secret"

# Admin account (created on server startup, not via public registration)
ADMIN_EMAIL="admin@larptube.ru"
ADMIN_PASSWORD="change-me-strong-password-with-letters-and-numbers"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# SMTP for email login codes (Gmail: use app password, not account password)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="LarpTubeX <noreply@larptubex.ru>"
